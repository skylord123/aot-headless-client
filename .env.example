# Age of Time minimal bot — configuration template.
# Copy this file to `.env` and fill in real values. The real `.env` is gitignored.
# Every variable here is read by aotbot/config.py at startup; the effective config
# (with the password redacted) is logged on launch.

# --- Age of Time game server ---
# Host/IP of the AoT server. OPTIONAL: leave blank to auto-resolve it from the
# master server list (AOT_MASTER_URL below) at connect time. Set it explicitly
# to connect to a specific server/IP and skip the master-server lookup.
AOT_SERVER_HOST=
# UDP port (not advertised by the master server, so it defaults to 28000).
AOT_SERVER_PORT=28000
# Master server list URL, parsed for its "IP <addr>" line when AOT_SERVER_HOST
# is blank. Defaults to the official list below.
AOT_MASTER_URL=https://master.ageoftime.com/server.txt

# --- Bot account credentials ---
# Username and password for the in-game account. The password is never sent in
# clear: login uses commandToServer('login', user, getStringCRC(pass)).
AOT_USERNAME=
AOT_PASSWORD=

# --- Auto-create character ---
# If login fails with "Character does not exist!", register the character and
# log in (mirrors the in-game bot's CREATE_USER flow). Appearance is randomized.
AOT_CREATE_USER=false
# Replace an existing character of the same name (rarely wanted).
AOT_CREATE_OVERWRITE=false
# 7 space-separated ability values (Str Sta Dex Agi Int Wis Cha), each 1-10.
# Leave blank for the default "1 1 1 1 1 1 1". e.g. Warrior = "10 10 1 5 1 1 1".
AOT_CREATE_ABILITIES=

# Character appearance. For EVERY field below, leave blank (or set -1) to
# RANDOMIZE a valid value; otherwise set the listed value. (Comments are on
# their own lines -- inline "# ..." after a value is not reliably stripped.)
AOT_CREATE_GENDER=
# 0 = Male, 1 = Female
AOT_CREATE_POSTURE=
# 0.0 - 1.0
AOT_CREATE_CHEST=
# 0.0 - 1.0
AOT_CREATE_X_SCALE=
# 0.9 - 1.1
AOT_CREATE_Y_SCALE=
# 0.9 - 1.1
AOT_CREATE_Z_SCALE=
# 0.9 - 1.1  (height ~ zScale * 66 inches)
AOT_CREATE_SKIN_TONE=
# 0 - 9
AOT_CREATE_LIP_TONE=
# 0 - 9  (a random value is clamped to >= skin tone)
AOT_CREATE_HAIR_STYLE=
# 0 = Part, 1 = Up, 2 = Exotic
AOT_CREATE_HAIR_COLOR=
# 0 = Blonde, 1 = Brown, 2 = Black, 3 = Red, 4 = White
AOT_CREATE_EYE_COLOR=
# 0 = Blue, 1 = Green, 2 = Brown, 3 = Black
AOT_CREATE_FACE=
# 0 = A, 1 = B
AOT_CREATE_EARS=
# 0 = Human, 1 = Elf
AOT_CREATE_GLASSES=
# 0 = Off, 1 = On

# --- Node-RED TCP bridge (optional) ---
# The bot connects as a TCP client to Node-RED to forward/receive chat.
# Outbound messages are terminated with three newlines; inbound is line-based.
# OPTIONAL: BOTH host and port must be set to enable Node-RED. Leave either one
# blank to disable the Node-RED connection. See docs/nodered-protocol.md.
NODERED_HOST=
NODERED_PORT=

# --- WebSocket server (optional) ---
# When WEBSOCKET_PORT is set, the bot HOSTS a WebSocket server that clients
# (Node-RED, a browser, a script) connect to for bi-directional JSON messaging.
# Every message is a JSON object with an "action" field (same action vocabulary
# as the Node-RED bridge). Leave WEBSOCKET_PORT blank/unset to NOT start the
# server. See docs/websocket-protocol.md.
#   - WEBSOCKET_HOST: interface to bind. Defaults to 0.0.0.0 (all interfaces);
#     use 127.0.0.1 to accept only local connections.
#   - WEBSOCKET_PORT: port to listen on (e.g. 8765).
# Node-RED and the WebSocket server are independent: enable either, both, or
# neither.
WEBSOCKET_HOST=0.0.0.0
WEBSOCKET_PORT=

# --- Behavior / debugging ---
# Logging verbosity: one of debug, info, warning, error, critical.
LOG_LEVEL=info

# Hexdump + bit-decode every UDP packet (very noisy; for handshake/CRC debugging).
# Accepts: true/false, 1/0, yes/no, on/off.
DUMP_PACKETS=false

# Skip the lighting/mission load steps and jump straight to logged-out in-game by
# acking MissionStartPhase2/3 immediately (mirrors base/skylord/bot/gameConnection.cs).
# Disable only if you intend to process the full mission load sequence.
AOT_SKIP_LIGHTING=true

# Live-entity telemetry. When true the bot decodes the ongoing ghost section and
# maintains a registry of scoped objects (the bot's own Player + nearby
# players/NPCs/items/world objects) exposing position, scale, rotation, datablock
# id, and shape name (.dts). Query it via Node-RED `list_objects` /
# `get_object <ghost_id>`, or the client list_objects()/get_object() API. When
# false (default) the ghost section is left untouched (chat/login still work,
# minimal CPU). Accepts: true/false, 1/0, yes/no, on/off.
AOT_TRACK_OBJECTS=false
